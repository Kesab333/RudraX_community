# Shared
NODE_ENV=development
APP_NAME=RudraX Unified Scientific Community Platform
APP_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_MAINTENANCE_MODE=false
WORKER_CONCURRENCY=5
MAINTENANCE_MODE=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REALTIME_TYPING=true
ENABLE_ATTACHMENTS=true
REQUEST_PAYLOAD_LIMIT_BYTES=5242880
MAX_UPLOADS_PER_USER=3
MAX_UPLOADS_PER_INSTANCE=12
HTTP_TIMEOUT_MS=10000
FILE_UPLOAD_TIMEOUT_MS=60000
WEBSOCKET_IDLE_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=5000
SLOW_QUERY_THRESHOLD_MS=200
SOFT_DELETE_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=30
DR_TEST_QUARTERLY=true

# Auth
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_ISSUER=rudrax-community
JWT_AUDIENCE=rudrax-community-users
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
COOKIE_DOMAIN=localhost
CSRF_SECRET=replace-me

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Infra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rudrax_community
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rudrax-community
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
MAIL_FROM=noreply@rudrax.local
MAIL_TRANSPORT_URL=smtp://localhost:1025

# Observability
ERROR_REPORTING_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
