{
  "name": "rudrax-community-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @rudrax/web --filter @rudrax/api --filter @rudrax/worker run dev",
    "dev:web": "pnpm --filter @rudrax/web dev",
    "dev:api": "pnpm --filter @rudrax/api start:dev",
    "dev:worker": "pnpm --filter @rudrax/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @rudrax/api prisma generate",
    "db:migrate": "pnpm --filter @rudrax/api prisma migrate dev",
    "db:deploy": "pnpm --filter @rudrax/api prisma migrate deploy"
  }
}
